{
  "manifest_version": 3,
  "name": "DigiOffice Mutatie Diff",
  "version": "1.0.0",
  "description": "Vergelijk mutaties in DigiOffice.",
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": ["diff.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "icons": {
    "16": "Icons/icon16.png",
    "48": "Icons/icon48.png",
    "128": "Icons/icon128.png"
  }
}
