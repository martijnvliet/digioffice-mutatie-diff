{
  "manifest_version": 3,
  "name": "DigiOffice Mutatie Diff",
  "version": "1.0",
  "description": "Vergelijk mutaties in DigiOffice.",
  "permissions": [],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["diff.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
